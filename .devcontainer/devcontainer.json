{
  "name": "DATA 730 Lecture Notebooks",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "hostRequirements": { "cpus": 4, "memory": "8gb" },
  "features": {
    "ghcr.io/prefix-dev/devcontainer-features/pixi:1": {}
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter",
        "ms-python.python",
        "REditorSupport.r"
      ]
    }
  }
}
